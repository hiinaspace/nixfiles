// Niri config for sayu, originally ported from the sway config (../sway/config).
// KDL format: https://kdl.dev  -- see the niri wiki for the full reference:
// https://yalter.github.io/niri/Configuration:-Introduction
//
// KEYBINDS: the `binds` block below now follows niri's own upstream defaults
// (https://github.com/niri-wm/niri/wiki/Getting-Started and
// resources/default-config.kdl), not the ported sway binds -- niri's scheme
// covers more than the original sway config did (per-column/window resize
// presets, consume/expel, overview, real maximize, etc). The only deviation
// from upstream is the modifier: `Mod` (Super on a TTY) is swapped for Alt
// throughout, since his UHK "window hold" button emits Alt.
// - niri is column/scroll based (like scroll, which he already uses): left/right
//   move between *columns*, up/down move between *windows stacked in a column*.
// - Anything with no clean niri equivalent is left as a `// TODO:` below.

// ─────────────────────────────────────────────────────────────────────────────
// Input  (sway: `focus_follows_mouse no`, no touchpad/keyboard tuning)
// ─────────────────────────────────────────────────────────────────────────────
input {
    keyboard {
        xkb {
            // sway used the system default layout; leaving this empty makes niri
            // fetch xkb settings from org.freedesktop.locale1 (localectl), same idea.
        }
        // sway didn't force numlock; leave it to firmware/BIOS. Uncomment to force on:
        // numlock
    }

    // Desktop machine, no touchpad configured in sway; leaving mouse/touchpad at
    // defaults (no accel override, matches sway which set none).

    // sway had `focus_follows_mouse no` (annoying on the wayvr overlay). niri's
    // focus-follows-mouse is OFF by default, so we simply do NOT enable it here.
}

// ─────────────────────────────────────────────────────────────────────────────
// Outputs  (sway: `output DP-5 {...}` / `output DP-6 {...}`)
// Positions are LOGICAL (scaled) pixels in both sway and niri, so they carry over.
// DP-5 at scale 1.5 => logical 2560x1440, so DP-6 sits at x=2560 to its right.
// ─────────────────────────────────────────────────────────────────────────────
output "DP-5" {
    mode "3840x2160"
    scale 1.5
    position x=0 y=0
    backdrop-color "#000000"
}

output "DP-6" {
    mode "2560x1440"
    position x=2560 y=-510
    transform "270"
    backdrop-color "#000000"

    layout {
        default-column-width { proportion 1.0; }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Cursor  (home.nix sets pointerCursor Adwaita/24 with sway.enable=true, which
// does NOT cover niri, so pin it here to match.)
// ─────────────────────────────────────────────────────────────────────────────
cursor {
    xcursor-theme "Adwaita"
    xcursor-size 24
}

// ─────────────────────────────────────────────────────────────────────────────
// Layout / appearance
// sway used `default_border pixel` + `hide_edge_borders smart_no_gaps` (thin
// borders, no gaps) and red-on-black focus colors (client.focused #cc0000).
// niri has no titlebars; we express the focus color via the focus ring.
// ─────────────────────────────────────────────────────────────────────────────
layout {
    gaps 0

    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 1.0
    }

    default-column-width { proportion 0.5; }

    // Red focus ring to mirror sway's client.focused border (#cc0000 on #600000).
    focus-ring {
        width 1
        active-color "#cc0000"
        inactive-color "#600000"
    }

    // sway drew only a thin pixel border; keep niri's separate border off and rely
    // on the focus ring above.
    border {
        off
    }

    background-color "#000000"
}

// ─────────────────────────────────────────────────────────────────────────────
// Startup  (sway: `exec`/`exec_always` and `bar swaybar_command waybar`)
// ─────────────────────────────────────────────────────────────────────────────

// sway ran waybar as its bar. NOTE: his waybar config.jsonc uses sway/workspaces,
// sway/mode and sway/window modules, which need swaymsg and will NOT populate
// under niri. waybar still launches; see the report for the niri/* module swap.
spawn-at-startup "waybar"

// sway idle: `swayidle -w timeout 600 'swaymsg "output * power off"' resume ...`.
// swaymsg doesn't exist under niri, so drive niri's own power-off action instead.
// niri turns monitors back on automatically on any input, so no explicit resume.
spawn-at-startup "swayidle" "-w" "timeout" "600" "niri msg action power-off-monitors"

// screenshots land here (niri's built-in screenshot also copies to the clipboard,
// which is all his sway grim|wl-copy binds did).
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

hotkey-overlay {
    // sway had no such popup; skip niri's startup hotkey overlay.
    skip-at-startup
}

// ─────────────────────────────────────────────────────────────────────────────
// Window rules  (sway: `for_window [...]`)
// ─────────────────────────────────────────────────────────────────────────────

// pikeru file picker (launched by xdg-desktop-portal, title "File Picker", no
// app_id). sway floated it and pulled it to the current workspace so it didn't
// tile off-screen on another monitor. niri opens floating windows on the active
// workspace, centered, by default -- so open-floating covers it.
window-rule {
    match title="^File Picker$"
    open-floating true
}

// TODO(sway->niri): `for_window [class="Firefox" window_role="alert"] floating enable`
// and `no_focus [window_role="alert"]`. niri matches on app-id/title only; it has
// no window_role matcher (an X11 concept) and no no_focus rule. No faithful port.

// TODO(sway->niri): `focus_on_window_activation focus` (obsidian web-clipper
// workaround). niri has no config knob to auto-focus windows that request
// activation; it surfaces them as "urgent" instead. No faithful port.

// ─────────────────────────────────────────────────────────────────────────────
// Key bindings -- niri upstream defaults, with Mod = Alt.
// (resources/default-config.kdl, https://github.com/niri-wm/niri/wiki/Getting-Started)
// ─────────────────────────────────────────────────────────────────────────────
binds {
    Alt+Shift+Slash { show-hotkey-overlay; }

    // --- Basics --- (spawn commands are ours; upstream default spawns alacritty/fuzzel)
    Alt+T            hotkey-overlay-title="Terminal: kitty" { spawn "kitty" "--single-instance"; }
    Alt+D            hotkey-overlay-title="Launcher: fuzzel" { spawn "fuzzel"; }
    Alt+Shift+Return hotkey-overlay-title="Firefox" { spawn "firefox"; }

    Alt+O repeat=false { toggle-overview; }
    Alt+Q repeat=false { close-window; }

    // --- Focus (left/right = columns, up/down = windows within a column) ---
    Alt+Left  { focus-column-left; }
    Alt+Down  { focus-window-down; }
    Alt+Up    { focus-window-up; }
    Alt+Right { focus-column-right; }
    Alt+H     { focus-column-left; }
    Alt+J     { focus-window-down; }
    Alt+K     { focus-window-up; }
    Alt+L     { focus-column-right; }

    // --- Move ---
    Alt+Ctrl+Left  { move-column-left; }
    Alt+Ctrl+Down  { move-window-down; }
    Alt+Ctrl+Up    { move-window-up; }
    Alt+Ctrl+Right { move-column-right; }
    Alt+Ctrl+H     { move-column-left; }
    Alt+Ctrl+J     { move-window-down; }
    Alt+Ctrl+K     { move-window-up; }
    Alt+Ctrl+L     { move-column-right; }

    Alt+Home { focus-column-first; }
    Alt+End  { focus-column-last; }
    Alt+Ctrl+Home { move-column-to-first; }
    Alt+Ctrl+End  { move-column-to-last; }

    // --- Multi-monitor (was Alt+M/Alt+Shift+M; M is now maximize below) ---
    Alt+Shift+Left  { focus-monitor-left; }
    Alt+Shift+Down  { focus-monitor-down; }
    Alt+Shift+Up    { focus-monitor-up; }
    Alt+Shift+Right { focus-monitor-right; }
    Alt+Shift+H     { focus-monitor-left; }
    Alt+Shift+J     { focus-monitor-down; }
    Alt+Shift+K     { focus-monitor-up; }
    Alt+Shift+L     { focus-monitor-right; }

    Alt+Ctrl+Shift+Left  { move-column-to-monitor-left; }
    Alt+Ctrl+Shift+Down  { move-column-to-monitor-down; }
    Alt+Ctrl+Shift+Up    { move-column-to-monitor-up; }
    Alt+Ctrl+Shift+Right { move-column-to-monitor-right; }
    Alt+Ctrl+Shift+H     { move-column-to-monitor-left; }
    Alt+Ctrl+Shift+J     { move-column-to-monitor-down; }
    Alt+Ctrl+Shift+K     { move-column-to-monitor-up; }
    Alt+Ctrl+Shift+L     { move-column-to-monitor-right; }

    // --- Workspaces (dynamic, per-monitor -- unlike sway's flat global set) ---
    Alt+Page_Down      { focus-workspace-down; }
    Alt+Page_Up        { focus-workspace-up; }
    Alt+U              { focus-workspace-down; }
    Alt+I              { focus-workspace-up; }
    Alt+Ctrl+Page_Down { move-column-to-workspace-down; }
    Alt+Ctrl+Page_Up   { move-column-to-workspace-up; }
    Alt+Ctrl+U         { move-column-to-workspace-down; }
    Alt+Ctrl+I         { move-column-to-workspace-up; }

    Alt+Shift+Page_Down { move-workspace-down; }
    Alt+Shift+Page_Up   { move-workspace-up; }
    Alt+Shift+U         { move-workspace-down; }
    Alt+Shift+I         { move-workspace-up; }

    Alt+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Alt+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Alt+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Alt+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    Alt+WheelScrollRight      { focus-column-right; }
    Alt+WheelScrollLeft       { focus-column-left; }
    Alt+Ctrl+WheelScrollRight { move-column-right; }
    Alt+Ctrl+WheelScrollLeft  { move-column-left; }

    Alt+Shift+WheelScrollDown      { focus-column-right; }
    Alt+Shift+WheelScrollUp        { focus-column-left; }
    Alt+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Alt+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    // Index-based workspace focus (best-effort -- niri workspaces are dynamic).
    // Alt+0 -> ws 10 kept from the old sway-style config; not part of upstream default.
    Alt+1 { focus-workspace 1; }
    Alt+2 { focus-workspace 2; }
    Alt+3 { focus-workspace 3; }
    Alt+4 { focus-workspace 4; }
    Alt+5 { focus-workspace 5; }
    Alt+6 { focus-workspace 6; }
    Alt+7 { focus-workspace 7; }
    Alt+8 { focus-workspace 8; }
    Alt+9 { focus-workspace 9; }
    Alt+0 { focus-workspace 10; }
    Alt+Ctrl+1 { move-column-to-workspace 1; }
    Alt+Ctrl+2 { move-column-to-workspace 2; }
    Alt+Ctrl+3 { move-column-to-workspace 3; }
    Alt+Ctrl+4 { move-column-to-workspace 4; }
    Alt+Ctrl+5 { move-column-to-workspace 5; }
    Alt+Ctrl+6 { move-column-to-workspace 6; }
    Alt+Ctrl+7 { move-column-to-workspace 7; }
    Alt+Ctrl+8 { move-column-to-workspace 8; }
    Alt+Ctrl+9 { move-column-to-workspace 9; }
    Alt+Ctrl+0 { move-column-to-workspace 10; }

    // Upstream default leaves workspace-back-and-forth commented out on Mod+Tab;
    // bound here to replace sway's `workspace back_and_forth` (was on Alt+C).
    Alt+Tab { focus-workspace-previous; }

    // --- Column/window manipulation ---
    Alt+BracketLeft  { consume-or-expel-window-left; }
    Alt+BracketRight { consume-or-expel-window-right; }
    Alt+Comma  { consume-window-into-column; }
    Alt+Period { expel-window-from-column; }

    Alt+R             { switch-preset-column-width; }
    Alt+Shift+R       { switch-preset-column-width-back; }
    Alt+Ctrl+Shift+R  { switch-preset-window-height; }
    Alt+Ctrl+R        { reset-window-height; }

    // sway `$mod+f` was true fullscreen; niri splits maximize/fullscreen/maximize-to-edges.
    Alt+F       { maximize-column; }
    Alt+Shift+F { fullscreen-window; }
    Alt+M       { maximize-window-to-edges; }        // was focus-monitor-right; see above

    Alt+Ctrl+F { expand-column-to-available-width; }
    Alt+C      { center-column; }
    Alt+Ctrl+C { center-visible-columns; }

    // Finer resize.
    Alt+Minus       { set-column-width "-10%"; }
    Alt+Equal       { set-column-width "+10%"; }
    Alt+Shift+Minus { set-window-height "-10%"; }
    Alt+Shift+Equal { set-window-height "+10%"; }

    // sway `$mod+Shift+space floating toggle` / `$mod+space focus mode_toggle`.
    Alt+V       { toggle-window-floating; }
    Alt+Shift+V { switch-focus-between-floating-and-tiling; }

    // sway `$mod+w layout tabbed` -> niri tabbed column display.
    Alt+W { toggle-column-tabbed-display; }

    // TODO(sway->niri, no equivalent):
    //   $mod+b splith / $mod+v splitv  -> niri has no h/v split (column model)
    //   $mod+s layout stacking         -> niri has tabbed columns but no "stacking"
    //   $mod+e layout toggle split     -> no split modes in niri
    //   $mod+a focus parent            -> niri has no parent containers (flat columns)
    // TODO(sway->niri, no equivalent): scratchpad. niri has no scratchpad concept.

    // --- Screenshots (sway: grim -g "$(slurp)" | wl-copy) ---
    // niri's built-in screenshot is interactive region select -> clipboard (+disk).
    Print       { screenshot; }
    Ctrl+Print  { screenshot-screen; }
    Alt+Print   { screenshot-window; }

    // --- Media / brightness keys (sway: --locked ... pactl / brightnessctl) ---
    // `--locked` -> `allow-when-locked=true`. Kept pactl (his choice), not wpctl.
    XF86AudioMute        allow-when-locked=true { spawn "pactl" "set-sink-mute" "@DEFAULT_SINK@" "toggle"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "-5%"; }
    XF86AudioRaiseVolume allow-when-locked=true { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "+5%"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "pactl" "set-source-mute" "@DEFAULT_SOURCE@" "toggle"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "set" "5%-"; }
    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "set" "5%+"; }

    // Escape hatch to release the shortcut inhibitor (niri-recommended). This is
    // now the only bind for it -- sway's passthrough mode (`$mod+u`) is dropped
    // since U now switches workspaces, per upstream default.
    Alt+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    // sway `$mod+Shift+e` ran a swaynag confirm-exit; niri's quit shows its own
    // confirmation dialog.
    Alt+Shift+E     { quit; }
    Ctrl+Alt+Delete { quit; }

    Alt+Shift+P { power-off-monitors; }

    // TODO(sway->niri): `$mod+Shift+c reload`. niri hot-reloads config.kdl on save
    // automatically, so there's no reload keybind to port.
}
